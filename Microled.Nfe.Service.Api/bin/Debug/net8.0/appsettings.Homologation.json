{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microled.Nfe.Service": "Debug"
    }
  },
  "Features": {
    "UseFakeGateway": false
  },
  "NfeService": {
    "BaseUrl": "https://nfehomologacao.prefeitura.sp.gov.br/ws/lotenfe.asmx",
    "TimeoutSeconds": 60,
    "Environment": "Homologation",
    "DefaultIssuerCnpj": "YOUR_CNPJ_HERE",
    "DefaultIssuerIm": "YOUR_IM_HERE",
    "DefaultCnpjRemetente": "YOUR_CNPJ_HERE",
    "SchemaVersion": "2.0",
    "Versao": "2",
    "LogRawXml": true,
    "LogSensitiveData": false,
    "Certificate": {
      "Mode": "File",
      "FilePath": "C:\\certs\\nfe-sp-homolog.pfx",
      "Password": "YOUR_CERTIFICATE_PASSWORD_HERE",
      "StoreLocation": "CurrentUser",
      "StoreName": "My",
      "Thumbprint": ""
    }
  }
}
